<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox spacing="15" alignment="CENTER"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phantomstormx.ceasercypherjava.CipherController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Image at Top -->
<!--    <ImageView fitHeight="150"-->
<!--               fitWidth="150"-->
<!--               preserveRatio="true">-->
<!--        <image>-->
<!--            <Image url="file:///var/folders/qq/03gytprn3y31573b5vl0jvm40000gp/T/TemporaryItems/NSIRD_screencaptureui_pKbhmM/Screenshot%202026-04-28%20at%2011.01.25.png" />-->
<!--        </image>-->

<!--    </ImageView>-->

    <!-- Title -->
    <Label text="Caesar Cipher Encoder / Decoder"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />


    <Label text="Input Text:" />
    <TextArea fx:id="inputText"
              prefHeight="100"
              wrapText="true"
              promptText="Enter Input Text Here." />


    <HBox spacing="10" alignment="CENTER">
        <Label text="Shift Number:" />
        <TextField fx:id="shiftField"
                   prefWidth="80"
                   promptText="Put Shift Integer Here" />
    </HBox>


    <HBox spacing="20" alignment="CENTER">
        <Button text="Encode"
                fx:id="handleEncrypt"
                onAction="#handleEncrypt" />

        <Button text="Decode"
                fx:id="handleDecode"
                onAction="#handleDecode" />

        <Button text="Clear"
                fx:id="handleClear"
                onAction="#handleClear" />
    </HBox>


    <Label text="Output Text:" />
    <TextArea fx:id="outputText"
              prefHeight="100"
              wrapText="true"
              editable="false"
              promptText="Output Text will Appear Here" />

    <!-- Exit Button -->
    <Button text="Exit"
            fx:id="handleExit"
            onAction="#handleExit"
            prefWidth="100" />

</VBox>